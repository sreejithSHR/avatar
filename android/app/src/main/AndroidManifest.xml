<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network for CDN imports (Three.js, XRBlocks, Gemini) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Microphone for Gemini Voice AI -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Camera for Vision Analysis passthrough -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Keep screen on during XR sessions -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Hardware features (all optional so app installs on any device) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <!-- Quest head tracking — optional so it sideloads on Quest and non-Quest -->
    <uses-feature android:name="android.hardware.vr.headtracking" android:required="false" android:version="1" />

    <application
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.AvatarXR">

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|uiMode|density|screenLayout|fontScale"
            android:exported="true"
            android:hardwareAccelerated="true"
            android:launchMode="singleTask"
            android:resizeableActivity="false"
            android:screenOrientation="landscape">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- Tells Quest to launch this in VR/MR mode instead of flat panel -->
                <category android:name="com.oculus.intent.category.VR" />
            </intent-filter>

            <!-- Required for Quest to treat this as a focus-aware VR app -->
            <meta-data android:name="com.oculus.vr.focusaware" android:value="true" />

        </activity>
    </application>

</manifest>
