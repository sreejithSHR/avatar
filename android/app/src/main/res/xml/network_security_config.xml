<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows the WebView to reach CDN sources (Three.js, XRBlocks, Gemini SDK)
    and local file:// assets without TLS errors blocking the importmap.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
